{
  "name": "amazon-scraper-api-sdk",
  "publishConfig": { "access": "public" },
  "version": "0.1.4",
  "description": "Official Node.js SDK for Amazon Scraper API (https://amazonscraperapi.com)",
  "keywords": ["amazon", "scraper", "api", "product-data", "asin", "web-scraping"],
  "license": "MIT",
  "author": "Amazon Scraper API",
  "homepage": "https://amazonscraperapi.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChocoData-com/amazon-scraper-api-sdk-node.git"
  },
  "bugs": "https://github.com/ChocoData-com/amazon-scraper-api-sdk-node/issues",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
